{
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "TodoWrite",
      "TaskCreate",
      "TaskUpdate",
      "TaskGet",
      "TaskList",

      "PowerShell(pnpm:*)",
      "PowerShell(npx:*)",
      "PowerShell(npm:*)",
      "PowerShell(turbo:*)",
      "PowerShell(node:*)",
      "PowerShell(tsc:*)",
      "PowerShell(vitest:*)",
      "PowerShell(vite:*)",

      "PowerShell(docker:*)",
      "PowerShell(docker-compose:*)",

      "PowerShell(git status)",
      "PowerShell(git status:*)",
      "PowerShell(git diff)",
      "PowerShell(git diff:*)",
      "PowerShell(git log)",
      "PowerShell(git log:*)",
      "PowerShell(git show)",
      "PowerShell(git show:*)",
      "PowerShell(git add)",
      "PowerShell(git add:*)",
      "PowerShell(git commit)",
      "PowerShell(git commit:*)",
      "PowerShell(git branch)",
      "PowerShell(git branch:*)",
      "PowerShell(git checkout:*)",
      "PowerShell(git switch:*)",
      "PowerShell(git stash)",
      "PowerShell(git stash:*)",
      "PowerShell(git restore:*)",
      "PowerShell(git tag:*)",
      "PowerShell(git config --get:*)",

      "PowerShell(Set-Location:*)",
      "PowerShell(New-Item:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Get-Item:*)",
      "PowerShell(Get-Date:*)",
      "PowerShell(Get-Process:*)",
      "PowerShell(Copy-Item:*)",
      "PowerShell(Move-Item:*)",
      "PowerShell(Rename-Item:*)",
      "PowerShell(Out-Null:*)",
      "PowerShell(Out-String:*)",
      "PowerShell(Select-Object:*)",
      "PowerShell(Where-Object:*)",
      "PowerShell(ForEach-Object:*)",
      "PowerShell(Measure-Object:*)",
      "PowerShell(Sort-Object:*)",
      "PowerShell(ConvertFrom-Json:*)",
      "PowerShell(ConvertTo-Json:*)",
      "PowerShell(Start-Sleep:*)",

      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(which:*)"
    ],
    "deny": [
      "PowerShell(git push:*)",
      "PowerShell(git push --force:*)",
      "PowerShell(git reset --hard:*)",
      "PowerShell(git rebase:*)",
      "PowerShell(git clean -f:*)",
      "PowerShell(git branch -D:*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(rm:*)",
      "PowerShell(rmdir:*)",
      "PowerShell(Stop-Process:*)",
      "PowerShell(Set-ExecutionPolicy:*)"
    ]
  }
}
