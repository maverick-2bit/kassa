[Unit]
Description=Kassa KDS-Display (nginx)
After=backend.service

[Container]
ContainerName=kds
# In Produktion auf ein :<sha>-Tag pinnen (Rollback). NICHT auto-updaten.
Image=ghcr.io/maverick-2bit/kassa-kds:latest
Network=kassa.network
PublishPort=8080:80

[Service]
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
