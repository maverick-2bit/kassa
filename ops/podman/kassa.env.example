# =============================================================================
# Secrets/Config für den Kassa-Podman-Stack.
#   sudo install -D -m 600 ops/podman/kassa.env.example /etc/kassa/kassa.env
#   sudo $EDITOR /etc/kassa/kassa.env
# Wird von postgres/backend/backup als EnvironmentFile geladen (Frontends nicht).
# Datei NUR root-lesbar halten (chmod 600).
# =============================================================================

# Datenbank — POSTGRES_PASSWORD muss zum Passwort in DATABASE_URL passen!
POSTGRES_PASSWORD=sicheres_db_passwort_hier
DATABASE_URL=postgresql://kassa:sicheres_db_passwort_hier@postgres:5432/kassa

# Backend-Sicherheit (siehe packages/backend/.env.example für Hinweise)
MASTER_PASSPHRASE=mindestens_sechzehn_zeichen
JWT_SECRET=mindestens_32_zeichen_langer_zufaelliger_schluessel
JWT_EXPIRES_IN=8h
LOG_LEVEL=info
CORS_ORIGIN=http://localhost
DB_BACKUP_RETENTION=30

# Externes Monitoring (leer = Endpoint deaktiviert)
MONITORING_TOKEN=

# Off-Site-Backup (leer = Backup-Service idle). Siehe Wurzel-.env.example.
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
RESTIC_S3_ACCESS_KEY_ID=
RESTIC_S3_SECRET_ACCESS_KEY=
RESTIC_KEEP_DAILY=14
RESTIC_KEEP_WEEKLY=8
RESTIC_KEEP_MONTHLY=84
BACKUP_STUNDE=4
