[Unit]
Description=Kassa Kellner-App (nginx)
After=backend.service

[Container]
ContainerName=kellner
# In Produktion auf ein :<sha>-Tag pinnen (Rollback). NICHT auto-updaten.
Image=ghcr.io/maverick-2bit/kassa-kellner:latest
Network=kassa.network
PublishPort=8083:80

[Service]
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
