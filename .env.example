# =============================================================================
# Kassa – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
#   cp .env.example .env
# =============================================================================

# ── Datenbank ─────────────────────────────────────────────────────────────────
# Passwort für den PostgreSQL-Datenbankbenutzer "kassa"
# Mindestens 20 Zeichen, zufällig generiert empfohlen:
#   node -e "console.log(require('crypto').randomBytes(20).toString('hex'))"
POSTGRES_PASSWORD=sicheres_db_passwort_hier_eintragen


# ── Backend-Sicherheit ────────────────────────────────────────────────────────

# Mindestens 16 Zeichen.
# Wird zur AES-Verschlüsselung der RKSV-Zertifikats-Passphrasen verwendet.
# WARNUNG: Darf NIEMALS geändert werden, solange Kassen-Daten existieren —
#          die gespeicherten Verschlüsselungen werden sonst unlesbar!
MASTER_PASSPHRASE=mindestens_sechzehn_zeichen_lang

# Mindestens 32 Zeichen.
# Wird zum Signieren der JWT-Tokens verwendet.
# Generieren:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=mindestens_32_zeichen_langer_zufaelliger_schluessel_hier_eintragen

# Gültigkeitsdauer der JWT-Tokens (z.B. "8h", "24h", "7d")
JWT_EXPIRES_IN=8h


# ── Optionale Einstellungen ───────────────────────────────────────────────────

# Log-Level des Backends: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Erlaubte CORS-Herkunft (URL, unter der das Frontend erreichbar ist)
# Im Docker-Compose-Setup: http://localhost  (oder deine Domain)
CORS_ORIGIN=http://localhost

# Port, auf dem das Frontend (nginx) von außen erreichbar ist
# Standard: 80  (für HTTPS-Setups: 443 und Reverse-Proxy vorschalten)
FRONTEND_PORT=80

# Port, auf dem das KDS-Display von außen erreichbar ist
# Aufruf: http://<server>:8080?station=kueche&token=<jwt>
KDS_PORT=8080

# Port, auf dem das Kundendisplay von außen erreichbar ist
# Aufruf: http://<server>:8081?kasseId=<uuid>
KUNDENDISPLAY_PORT=8081

# ── Off-Site-Backup (optional, aber für eine Kasse dringend empfohlen) ────────
# Schiebt die DB-/DEP-Sicherungen verschlüsselt an externen S3-kompatiblen
# Object-Storage (Backblaze B2, Wasabi, Hetzner, AWS S3, MinIO …).
# Ohne RESTIC_REPOSITORY/RESTIC_PASSWORD ist das Backup deaktiviert (opt-in).
#
# Repository-URL, z. B.:
#   s3:https://s3.eu-central-003.backblazeb2.com/mein-kassa-bucket
# RESTIC_REPOSITORY=s3:https://<endpoint>/<bucket>
#
# Verschlüsselungspasswort des Repos — SEPARAT und SICHER aufbewahren!
# Bei Verlust ist das Backup unwiederbringlich. Generieren:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# RESTIC_PASSWORD=langes_zufaelliges_repo_passwort
#
# S3-Zugangsdaten (Application Key des Object-Storage-Providers)
# RESTIC_S3_ACCESS_KEY_ID=
# RESTIC_S3_SECRET_ACCESS_KEY=
#
# Aufbewahrung im externen Repo (Default: 14 täglich / 8 wöchentlich / 84 monatlich = 7 Jahre)
# RESTIC_KEEP_DAILY=14
# RESTIC_KEEP_WEEKLY=8
# RESTIC_KEEP_MONTHLY=84
# Lauf-Uhrzeit (Stunde, Containerzeit) — nach den Backend-Crons:
# BACKUP_STUNDE=4

# ── SMTP (optional — E-Mail-Belegversand) ────────────────────────────────────
# Wenn SMTP_HOST nicht gesetzt ist, ist der E-Mail-Versand deaktiviert.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=kassa@example.com
# SMTP_PASS=sicheres_passwort
# SMTP_FROM=Kassa <kassa@example.com>
