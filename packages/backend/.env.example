# PostgreSQL Verbindung
DATABASE_URL=postgresql://kassa:kassa@localhost:5432/kassa

# Master-Passphrase für die Verschlüsselung der SEE-privaten Schlüssel.
# WICHTIG: In Produktion muss dies ein langes, zufälliges Geheimnis sein,
# das NIE im Repo landet. Bei Verlust ist KEIN SEE-Schlüssel mehr entschlüsselbar
# und die Kasse muss neu eingerichtet werden.
MASTER_PASSPHRASE=dev-only-change-me-in-production

# JWT-Signing-Key (mind. 32 Zeichen)
# In Produktion: openssl rand -base64 48
JWT_SECRET=dev-only-jwt-secret-please-change-in-production-environment
JWT_EXPIRES_IN=8h

# Server-Port
PORT=3000

# Log-Level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# CORS Origin (Frontend-URL). Komma-separiert für mehrere.
CORS_ORIGIN=http://localhost:5173

# FinanzOnline stubben (true/false). Für lokale Entwicklung: ermöglicht die
# Kassen-Einrichtung OHNE echte FinanzOnline-Zugangsdaten. In Produktion
# verboten — das Backend bricht bei FO_STUB=true + NODE_ENV=production ab.
FO_STUB=false

# Externer Monitoring-Endpoint GET /api/monitoring/status?token=…
# (200 = gesund, 503 = degradiert). Nicht gesetzt = Endpoint deaktiviert (404).
# Für Uptime-Monitore (Healthchecks.io, Uptime Kuma). Langes Zufallstoken:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# MONITORING_TOKEN=
# Schwellen, ab denen eine Sicherung als "veraltet" (-> degradiert) gilt:
# DB_BACKUP_MAX_AGE_STUNDEN=26
# DEP_BACKUP_MAX_AGE_STUNDEN=26
