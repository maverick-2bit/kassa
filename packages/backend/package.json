{
  "name": "@kassa/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch --env-file=.env --experimental-strip-types src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@kassa/rksv": "workspace:*",
    "@kassa/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.4.5",
    "vitest": "^2.0.0"
  }
}
